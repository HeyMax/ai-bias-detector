{
  "manifest_version": 3,
  "name": "AI Bias Detector",
  "version": "0.1.0",
  "description": "Detect bias in AI recommendations. Don't trust AI blindly — get a second opinion.",
  "default_locale": "en",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://claude.ai/*",
    "https://poe.com/*",
    "https://raw.githubusercontent.com/HeyMax/ai-bias-detector/*",
    "https://cdn.jsdelivr.net/gh/HeyMax/ai-bias-detector@main/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://claude.ai/*",
        "https://poe.com/*"
      ],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
